---
layout: null
permalink: /feed.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <generator uri="https://www.11ty.dev/">Eleventy</generator>
  <link href="{{ '/feed.xml' | absolute_url | feed_utm_url | xml_escape }}" rel="self" type="application/atom+xml" />
  <link href="{{ '/' | absolute_url | feed_utm_url | xml_escape }}" rel="alternate" type="text/html" />
  <updated>{{ "now" | date_to_xmlschema }}</updated>
  <id>{{ '/feed.xml' | absolute_url | xml_escape }}</id>
  <title type="html">{{ site.title | xml_escape }}</title>
  <subtitle>{{ site.description | xml_escape }}</subtitle>
  <author>
    <name>{{ site.author.name | xml_escape }}</name>
    <email>{{ site.author.email | xml_escape }}</email>
    <uri>{{ site.author.uri | feed_utm_url | xml_escape }}</uri>
  </author>
  {% assign posts = collections.posts | where_visible %}
  {% for post in posts limit: 10 %}
  {% assign post_absolute_url = post.url | absolute_url %}
  <entry>
    <title type="html">{{ post.data.title | xml_escape }}</title>
    <link href="{{ post_absolute_url | feed_utm_url | xml_escape }}" rel="alternate" type="text/html" title="{{ post.data.title | xml_escape }}" />
    <published>{{ post.date | date_to_xmlschema }}</published>
    <updated>{{ post.date | date_to_xmlschema }}</updated>
    <id>{{ post.url | absolute_url | xml_escape }}</id>
    <content type="html" xml:base="{{ post_absolute_url | feed_utm_url | xml_escape }}"><![CDATA[{{ post.templateContent | feed_utm_html: post_absolute_url }}]]></content>
    <author>
      <name>{{ post.data.author | default: site.author.name | xml_escape }}</name>
      <email>{{ site.author.email | xml_escape }}</email>
      <uri>{{ site.author.uri | feed_utm_url | xml_escape }}</uri>
    </author>
    {% assign post_categories = post.data.categories | list_values %}
    {% for category in post_categories %}
    <category term="{{ category | xml_escape }}" />
    {% endfor %}
    {% assign post_tags = post.data.tags | list_values %}
    {% for tag in post_tags %}
    <category term="{{ tag | xml_escape }}" />
    {% endfor %}
  </entry>
  {% endfor %}
</feed>
